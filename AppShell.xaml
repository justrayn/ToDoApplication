<Shell
    x:Class="ToDoApplication.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:ToDoApplication.Pages"
    Shell.FlyoutBehavior="Disabled">

    <TabBar>
        <Tab Title="To Do">
            <ShellContent ContentTemplate="{DataTemplate pages:ToDoPage}" />
        </Tab>
        <Tab Title="Completed">
            <ShellContent ContentTemplate="{DataTemplate pages:CompletedPage}" />
        </Tab>
        <Tab Title="Profile">
            <ShellContent ContentTemplate="{DataTemplate pages:ProfilePage}" />
        </Tab>
    </TabBar>
</Shell>