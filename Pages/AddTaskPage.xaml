<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ToDoApplication.Pages.AddTaskPage"
             Title="Add Task">

    <VerticalStackLayout Padding="20" Spacing="15">
        <Entry x:Name="TitleEntry" Placeholder="Title" />
        <Editor x:Name="DetailsEntry" Placeholder="Details" HeightRequest="150" />

        <Button Text="Add Task" Clicked="OnAddClicked" BackgroundColor="#9ba1d8" HeightRequest="50" />
    </VerticalStackLayout>
</ContentPage>