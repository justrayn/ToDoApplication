<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ToDoApplication.Pages.SignInPage"
             Title="Sign In">

    <VerticalStackLayout Padding="30" Spacing="15" VerticalOptions="Center">
        <Image Source="dotnet_bot.png" HeightRequest="180" HorizontalOptions="Center" />
        
        <Entry x:Name="EmailEntry" Placeholder="Email address" Keyboard="Email" />
        <Entry x:Name="PasswordEntry" Placeholder="Password" IsPassword="True" />
        
        <Button Text="Sign in" Clicked="OnSignInClicked" 
                BackgroundColor="#9ba1d8" TextColor="White" HeightRequest="50" />
        
        <Button Text="Sign up" Clicked="OnSignUpRedirectClicked" 
                BackgroundColor="#e1e3f3" TextColor="#7b81b3" HeightRequest="50" />
    </VerticalStackLayout>
</ContentPage>