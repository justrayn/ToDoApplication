<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ToDoApplication.ViewModels"
             x:Class="ToDoApplication.Pages.ToDoPage"
             Title="My Tasks">


    <Grid RowDefinitions="*, Auto">
        
        <RefreshView Grid.Row="0" 
                     Command="{Binding RefreshCommand}" 
                     RefreshColor="#9ba1d8">
            
            <ListView ItemsSource="{Binding ToDoTasks}" 
                      ItemSelected="OnTaskSelected"
                      HasUnevenRows="True"
                      SeparatorVisibility="None"
                      BackgroundColor="Transparent">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <ViewCell>
                            <Frame Margin="10,5" 
                                   Padding="15" 
                                   BorderColor="#E1E3F3" 
                                   CornerRadius="12" 
                                   HasShadow="False"
                                   BackgroundColor="White">
                                
                                <Grid ColumnDefinitions="*, 40, 40" ColumnSpacing="5">
                                    <Label Grid.Column="0" 
                                           Text="{Binding Title}" 
                                           VerticalOptions="Center" 
                                           FontSize="16"
                                           TextColor="#333333"
                                           FontAttributes="Bold"
                                           LineBreakMode="TailTruncation" />

                                    <Button Grid.Column="1" 
                                            Text="🗑" 
                                            BackgroundColor="Transparent"
                                            TextColor="#FF6B6B"
                                            FontSize="18"
                                            Padding="0"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:TodoViewModel}}, Path=DeleteTaskCommand}"
                                            CommandParameter="{Binding .}" />

                                    <Button Grid.Column="2" 
                                            Text="✓" 
                                            BackgroundColor="Transparent"
                                            TextColor="#51CF66"
                                            FontSize="18"
                                            Padding="0"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:TodoViewModel}}, Path=CompleteTaskCommand}"
                                            CommandParameter="{Binding .}" />
                                </Grid>
                            </Frame>
                        </ViewCell>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </RefreshView>

        <Button Grid.Row="0" 
                Text="+" 
                FontSize="24"
                TextColor="White"
                Margin="0,0,20,20" 
                Clicked="OnAddTaskClicked"
                BackgroundColor="#9ba1d8" 
                CornerRadius="30" 
                WidthRequest="60" 
                HeightRequest="60"
                HorizontalOptions="End" 
                VerticalOptions="End"
                ZIndex="1"/>
    </Grid>
</ContentPage>