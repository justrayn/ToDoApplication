<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ToDoApplication.Pages.ProfilePage"
             Title="Profile">

    <VerticalStackLayout Padding="30" Spacing="30" VerticalOptions="Center">
        <Image Source="dotnet_bot.png" HeightRequest="150" />
        <Label x:Name="UsernameLabel" HorizontalOptions="Center" FontSize="20" FontAttributes="Bold" />

        <Button Text="Sign out" Clicked="OnSignOutClicked" BackgroundColor="#808080" />
    </VerticalStackLayout>
</ContentPage>