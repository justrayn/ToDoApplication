<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ToDoApplication.ViewModels"
             x:Class="ToDoApplication.Pages.CompletedPage"
             Title="Completed">

    <ContentPage.BindingContext>
        <vm:TodoViewModel x:Name="ViewModel" />
    </ContentPage.BindingContext>

    <ListView ItemsSource="{Binding CompletedTasks}" ItemSelected="OnTaskSelected">
        <ListView.ItemTemplate>
            <DataTemplate>
                <ViewCell>
                    <Frame Margin="10,5" Padding="10" BorderColor="#CCCCCC">
                        <HorizontalStackLayout Spacing="10">
                            <Label Text="{Binding Title}" VerticalOptions="Center" WidthRequest="250" TextDecorations="Strikethrough" />
                            <Label Text="🗑" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Frame>
                </ViewCell>
            </DataTemplate>
        </ListView.ItemTemplate>
    </ListView>
</ContentPage>