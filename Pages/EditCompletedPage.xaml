<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ToDoApplication.Pages.EditCompletedPage"
             Title="View Completed">

    <VerticalStackLayout Padding="20" Spacing="15">
        <Entry x:Name="TitleEntry" />
        <Editor x:Name="DetailsEntry" HeightRequest="150" />

        <Button Text="Update" Clicked="OnUpdateClicked" BackgroundColor="#9ba1d8" />
        <Button Text="Mark Incomplete" Clicked="OnIncompleteClicked" BackgroundColor="#E1E3F3" TextColor="#7b81b3" />
        <Button Text="Delete Permanently" Clicked="OnDeleteClicked" BackgroundColor="#ffc1cc" TextColor="#b36d7a" />
    </VerticalStackLayout>
</ContentPage>